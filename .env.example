# ============================================================
# ECOMMERCE ELT PIPELINE — ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to .env and fill in your actual values
# Never commit .env — it contains secrets

# PROJECT PATHS
DATA_DIR=/opt/data
PROJECT_DIR=/path/to/your/project

# DBT CONFIGURATION
DBT_PROFILES_DIR=/path/to/.dbt

# AIRFLOW METADATA DATABASE (Postgres)
POSTGRES_USER=airflow
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=airflow

# AIRFLOW CORE CONFIGURATION
AIRFLOW__CORE__EXECUTOR=CeleryExecutor
AIRFLOW__CELERY__BROKER_URL=redis://redis:6379/0
AIRFLOW__CELERY__RESULT_BACKEND=db+postgresql://airflow:your_password@postgres/airflow
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__FERNET_KEY=generate_with_command_below
# python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# AIRFLOW WEBSERVER CONFIGURATION
AIRFLOW__WEBSERVER__SECRET_KEY=your_secret_key_here
AIRFLOW__WEBSERVER__RATE_LIMIT_STORAGE_URL=redis://redis:6379/0

# AIFRLOW DATABASE CONFIGURATION
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:your_password@postgres:5432/airflow
AIRFLOW__DATABASE__SQL_ALCHEMY_POOL_RECYCLE=1800
AIRFLOW__DATABASE__SQL_ALCHEMY_POOL_PRE_PING=True

# AIRFLOW ADMIN USER
# Credentials for the Airflow UI login
AIRFLOW_ADMIN_USERNAME=airflow
AIRFLOW_ADMIN_PASSWORD=your_password_here
AIRFLOW_ADMIN_FIRSTNAME=Your
AIRFLOW_ADMIN_LASTNAME=Name
AIRFLOW_ADMIN_EMAIL=your@email.com

# AIRFLOW USER PERMISSIONS
# On Linux run: echo -e "AIRFLOW_UID=$(id -u)" >> .env
# On WSL2 use 50000 (default non-root user)
AIRFLOW_UID=50000

# SNOWFLAKE CONNECTION
SNOWFLAKE_ACCOUNT=your_account_here
SNOWFLAKE_USER=your_user_here
SNOWFLAKE_PASSWORD=your_password_here
SNOWFLAKE_WAREHOUSE=your_warehouse_here
SNOWFLAKE_DATABASE=your_database_here
SNOWFLAKE_SCHEMA=bronze
SNOWFLAKE_ROLE=your_role_here

# ECOMMERCE POSTGRES (3NF Data Warehouse)
POSTGRES_ECOMMERCE_USER=ecommerce_user
POSTGRES_ECOMMERCE_PASSWORD=your_password_here
POSTGRES_ECOMMERCE_DB=ecommerce
POSTGRES_ECOMMERCE_HOST=ecommerce-postgres
POSTGRES_ECOMMERCE_PORT=5432

# pgAdmin credentials
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin